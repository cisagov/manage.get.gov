{
  "editor.rulers": [120],
  "files.exclude": {
    "**/__pycache__": true,
    "**/.pytest_cache": true,
    "src/registrar/public": true
  },
  "search.exclude": {
    "src/registrar/public": true,
    "**/node_modules": true,
    "**/*.lock": true,
    "**/Pipfile.lock": true,
    "**/package-lock.json": true
  },
  "github.copilot.chat.codeGeneration.useInstructionFiles": true,
  "python.languageServer": "Pylance"
}
